      "type": "string"
    },
    "customer_name": {
      "type": "string"
    },
    "rating": {
      "type": "integer"
    },
    "comment": {
      "type": "string"
    },
    "verified": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
